---
{
  "layout": "layout.njk",
  "title": "Sergey Fedorov",
  "description": "Engineer focused on building clean, reliable software.",
  "intro": "Hi, I'm Sergey.",
  "contacts": [
    {
      "label": "GitHub",
      "value": "Shade30",
      "href": "https://github.com/Shade30"
    },
    {
      "label": "Telegram",
      "value": "@svfedorov88",
      "href": "https://t.me/svfedorov88"
    },
    {
      "label": "LinkedIn",
      "value": "sergey-fedorov",
      "href": "https://www.linkedin.com/in/svfedorov/"
    }
  ]
}
---
<section class="hero">
  <p class="eyebrow">Personal page</p>
  <h1>{{ intro }}</h1>
  <p class="lede">{{ description }}</p>
</section>

<section class="contacts" aria-labelledby="contacts-title">
  <div class="section-head">
    <p class="section-kicker">Reach out</p>
    <h2 id="contacts-title">Contacts</h2>
  </div>
  <ul class="contact-list">
    {% for contact in contacts %}
      <li class="contact-item">
        <span class="contact-label">{{ contact.label }}</span>
        <a href="{{ contact.href }}" target="_blank" rel="noreferrer">{{ contact.value }}</a>
      </li>
    {% endfor %}
  </ul>
</section>
