<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{ title }}</title>
    <meta name="description" content="{{ description }}" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;700;800&family=Cormorant+Garamond:wght@500;600&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/styles/site.css" />
  </head>
  <body>
    <canvas class="background-canvas" data-tree-canvas></canvas>
    <div class="background-glow" aria-hidden="true"></div>
    <main class="shell">
      {{ content | safe }}
    </main>
    <script src="/scripts/tree-background.js" defer></script>
  </body>
</html>
